# =============================================================================
# Insightseel — 环境变量
# =============================================================================
# 将此文件复制到 .env.local 进行本地开发（切勿提交 .env.local）。
# 对于 Vercel：在“项目设置”→“环境变量”中设置这些变量。
# =============================================================================


# =============================================================================
# ✅ 必需 — LLM 配置（统一，单一入口点）
# =============================================================================
# 这三个变量控制所有摘要/洞察/分析的生成。
# 在 Vercel 中设置它们，一切即可运行 — 无需其他 LLM 变量。

# 您的 API 密钥。适用于 Gemini、OpenAI 或任何兼容 OpenAI 的提供商。
LLM_API_KEY=your_api_key_here

# LLM API 端点的基本 URL。
# Gemini（默认 — 如果使用 Google Gemini 则省略此行）：
#   https://generativelanguage.googleapis.com
# OpenAI：
#   https://api.openai.com/v1
# 任何兼容 OpenAI 的端点（OpenRouter、Azure、本地 Ollama 等）：
#   https://openrouter.ai/api/v1
LLM_BASE_URL=https://generativelanguage.googleapis.com

# 模型名称。必须与上述 LLM_BASE_URL 处可用的模型匹配。
# Gemini：gemini-2.5-flash | gemini-2.0-flash | gemini-1.5-pro
# OpenAI：gpt-4o-mini | gpt-4o
LLM_MODEL=gemini-2.5-flash


# =============================================================================
# ✅ 必需（前端构建时）— 启用代理路由
# =============================================================================
# 告诉前端将所有 LLM 调用通过 /api/proxy 路由（Vercel 部署必需 — 将您的 API 密钥保留在服务器端）。
VITE_USE_PROXY=true

# 可选：UI 设置面板中显示的模型名称（仅用于美观）。
VITE_MODEL=gemini-2.5-flash


# =============================================================================
# ✅ 必需 — Deepgram（用于字幕生成的语音转文本）
# =============================================================================
# 在 https://deepgram.com 获取 200 美元免费积分
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here


# =============================================================================
# 可选 — Supabase（云同步）
# =============================================================================
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key


# =============================================================================
# 旧版/高级提供商特定覆盖（通常不需要）
# =============================================================================
# 这些在 LLM_* 变量之后检查。仅当您需要与统一密钥一起使用每个提供商密钥时才使用（例如，用于 Whisper 的单独 OpenAI 密钥）。

# GEMINI_API_KEY=
# GEMINI_BASE_URL=
# GEMINI_MODEL=

# OPENAI_API_KEY=          ← 也用于 Whisper 转录
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=
# CUSTOM_MODEL=